# DeepSeek 配置
DEEPSEEK_API_KEY=your_deepseek_api_key
# 申请地址：https://platform.deepseek.com/api_keys

# 阿里云 DashScope 配置
ALIYUN_API_KEY=your_aliyun_api_key
# 申请地址：https://bailian.console.aliyun.com/?#/home

# AI API 超时设置（秒）
AI_API_TIMEOUT=120

# Axure 在线原型访问凭据（按需配置）
# AXURE_USERNAME=
# AXURE_PASSWORD=

# OCR 并发控制（可选）
# OCR_MAX_CONCURRENT=5
# OCR_TIMEOUT=60
# OCR_MAX_RETRIES=2
